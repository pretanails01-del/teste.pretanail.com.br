<script>
// ===== CONFIGURAÇÃO DE BLOQUEIO AUTOMÁTICO =====
// Aceita: "30s", "1min", "5min", "1h", "6h", "1d", "10d", "50d", "0" = infinito
const DURACAO_BLOQUEIO = "0"; // ← SÓ MUDA ESSA LINHA
const WHATSAPP_BLOQUEIO = "5511991233172"; // Teu número que vai no botão
// ============================================================

const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbwuuqYuvDyl5igfaY9LkC6dDus-KP8bQuWDMGLBXnY4bU41QAN3gNng5S5rj6D0vQs/exec";
const WHATSAPP_NUMBER = "5511982311608";

// CONVERTE "1d", "1h", "1min", "30s" PARA MINUTOS
function converterParaMinutos(tempo) {
  if (typeof tempo === 'number') return tempo;
  const valor = parseFloat(tempo);
  const unidade = tempo.toString().toLowerCase().replace(/[0-9.]/g, '');
  if (isNaN(valor) || valor <= 0) return 0;
  switch (unidade) {
    case 's': return valor / 60;
    case 'min':
    case 'm': return valor;
    case 'h': return valor * 60;
    case 'd': return valor * 60 * 24;
    default: return valor;
  }
}

// VERIFICA SE DEVE BLOQUEAR
(function verificarBloqueio() {
  const duracaoMinutos = converterParaMinutos(DURACAO_BLOQUEIO);
  if (duracaoMinutos <= 0) return; // 0 = infinito, nunca bloqueia

  const CHAVE_STORAGE = 'sistemaBloqueio_inicio';
  let dataInicio = localStorage.getItem(CHAVE_STORAGE);
  
  if (!dataInicio) {
    dataInicio = new Date().toISOString();
    localStorage.setItem(CHAVE_STORAGE, dataInicio);
  }

  const inicio = new Date(dataInicio).getTime();
  const agora = new Date().getTime();
  const minutosPassados = (agora - inicio) / 60000;

  if (minutosPassados >= duracaoMinutos) {
    document.getElementById('bloqueioOverlay').classList.remove('hidden');
    document.getElementById('mainContainer').style.display = 'none';
    document.body.style.overflow = 'hidden';
    
    // Atualiza link do WhatsApp no botão de bloqueio
    const btnWhats = document.querySelector('#bloqueioOverlay a');
    if (btnWhats) btnWhats.href = `https://wa.me/${WHATSAPP_BLOQUEIO}`;
  }
})();

let fotoBase64 = null;
let isDrawing = false;
let hasSignature = false;

function previewFoto(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('previewImg').src = e.target.result;
      document.getElementById('previewContainer').classList.remove('hidden');
      fotoBase64 = e.target.result;
    }
    reader.readAsDataURL(input.files[0]);
  }
}

function removerFoto() {
  document.getElementById('previewContainer').classList.add('hidden');
  document.getElementById('foto').value = '';
  fotoBase64 = null;
}

document.getElementById('outroCheck').addEventListener('change', function() {
  const container = document.getElementById('outroContainer');
  const campo = document.getElementById('outroTexto');
  if (this.checked) {
    container.classList.remove('hidden');
    campo.required = true;
  } else {
    container.classList.add('hidden');
    campo.required = false;
    campo.value = '';
  }
});

const canvas = document.getElementById('signatureCanvas');
const ctx = canvas.getContext('2d');
ctx.strokeStyle = '#1a1a1a';
ctx.lineWidth = 3;
ctx.lineCap = 'round';

function getPos(e) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.width / rect.width;
  const scaleY = canvas.height / rect.height;
  if (e.touches) {
    return {
      x: (e.touches[0].clientX - rect.left) * scaleX,
      y: (e.touches[0].clientY - rect.top) * scaleY
    };
  }
  return {
    x: (e.clientX - rect.left) * scaleX,
    y: (e.clientY - rect.top) * scaleY
  };
}

function startDraw(e) {
  isDrawing = true;
  hasSignature = true;
  const pos = getPos(e);
  ctx.beginPath();
  ctx.moveTo(pos.x, pos.y);
  e.preventDefault();
}

function draw(e) {
  if (!isDrawing) return;
  const pos = getPos(e);
  ctx.lineTo(pos.x, pos.y);
  ctx.stroke();
  e.preventDefault();
}

function endDraw() {
  isDrawing = false;
}

canvas.addEventListener('mousedown', startDraw);
canvas.addEventListener('mousemove', draw);
canvas.addEventListener('mouseup', endDraw);
canvas.addEventListener('mouseleave', endDraw);
canvas.addEventListener('touchstart', startDraw);
canvas.addEventListener('touchmove', draw);
canvas.addEventListener('touchend', endDraw);

function clearSignature() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  hasSignature = false;
}

function toggleDetalhes(select, textareaId) {
  const textarea = document.getElementById(textareaId);
  if (select.value === 'Sim') {
    textarea.classList.remove('hidden');
    textarea.required = true;
  } else {
    textarea.classList.add('hidden');
    textarea.required = false;
    textarea.value = '';
  }
}

function showErro(msg) {
  const container = document.getElementById('erroContainer');
  container.innerHTML = `<div class="erro-msg"><i class="fas fa-exclamation-triangle"></i> ${msg}</div>`;
  container.classList.remove('hidden');
  window.scrollTo({ top: container.offsetTop - 20, behavior: 'smooth' });
}

document.getElementById('anamneseForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  document.getElementById('erroContainer').classList.add('hidden');

  if (!hasSignature) {
    showErro('A assinatura digital é obrigatória. Por favor, assine no campo acima.');
    return;
  }

  let procs = [];
  document.querySelectorAll('#procedimentosGroup input[type="checkbox"]:checked').forEach(c => {
    if (c.value === 'Outro') {
      const outro = document.getElementById('outroTexto').value.trim();
      if (outro) procs.push(`Outro: ${outro}`);
    } else {
      procs.push(c.value);
    }
  });

  if (procs.length === 0) {
    showErro('Selecione pelo menos um procedimento desejado.');
    return;
  }

  const btn = document.getElementById('submitBtn');
  const btnText = document.getElementById('btnText');
  btn.disabled = true;
  btnText.innerHTML = '<span class="loader"></span>Enviando...';

  const dados = {
    nome: document.getElementById('nome').value.trim(),
    idade: document.getElementById('idade').value,
    whatsapp: document.getElementById('whatsapp').value.trim(),
    procedimento: procs.join(", "),
    outroTexto: document.getElementById('outroTexto').value,
    fotoReferencia: fotoBase64,
    assinatura: canvas.toDataURL('image/png'),
    alergias: document.getElementById('alergias').value,
    alergias_texto: document.getElementById('alergias_texto').value,
    medicamentos: document.getElementById('medicamentos').value,
    medicamentos_texto: document.getElementById('medicamentos_texto').value,
    gravida: document.getElementById('gravida').value,
    alongamento: document.getElementById('alongamento').value,
    alongamento_texto: document.getElementById('alongamento_texto').value,
    observacoes: document.getElementById('observacoes').value
  };

  try {
    const response = await fetch(WEB_APP_URL, {
      method: "POST",
      mode: "cors",
      body: JSON.stringify(dados)
    });

    const data = await response.json();

    if (data.status === 'ok') {
      document.getElementById('sucessoTexto').innerHTML = `Formulário ${data.os} enviado com sucesso!`;

      const texto = `*🔥 NOVO FORMULÁRIO - PRETA NAILS*%0A%0A*👤 Cliente:* ${dados.nome}%0A*📱 WhatsApp:* ${dados.whatsapp}%0A*💅 Procedimento:* ${dados.procedimento}%0A*📋 OS:* ${data.os}%0A%0A*📄 PDF:* ${data.pdf}`;
      const linkWhats = `https://wa.me/${WHATSAPP_NUMBER}?text=${texto}`;

      document.getElementById('btnWhatsContainer').innerHTML = `
        <a href="${linkWhats}" target="_blank" class="btn btn-primary" style="display:inline-block; margin-top:20px; text-decoration:none;">
          <i class="fab fa-whatsapp"></i> ABRIR WHATSAPP
        </a>
      `;

      document.getElementById('sucessoOverlay').classList.remove('hidden');

    } else {
      throw new Error(data.msg || 'Erro desconhecido');
    }
  } catch (err) {
    showErro('Erro ao enviar formulário. Verifique se implantou como "Qualquer pessoa" no Apps Script.');
    console.error(err);
    btn.disabled = false;
    btnText.textContent = 'ENVIAR FORMULÁRIO';
  }
});

document.getElementById('whatsapp').addEventListener('input', function(e) {
  let value = e.target.value.replace(/\D/g, '');
  if (value.length > 11) value = value.slice(0, 11);
  if (value.length > 6) {
    value = `(${value.slice(0,2)}) ${value.slice(2,7)}-${value.slice(7)}`;
  } else if (value.length > 2) {
    value = `(${value.slice(0,2)}) ${value.slice(2)}`;
  }
  e.target.value = value;
});
</script>
</body>
