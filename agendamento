<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agendar Horário - Preta Nails</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root { --preto:#0a0a0a; --rosa:#E91E63; --verde-whats:#25D366; --rosa-glow: rgba(233,30,99,0.4); --vidro: rgba(20,20,20,0.55); --borda: rgba(255,255,255,0.12); }
  *{box-sizing:border-box}
  body { font-family: 'Poppins', sans-serif; color:#fff; margin:0; min-height:100vh; display:flex; justify-content:center; align-items:center; padding:24px; background: #000 url('https://images.unsplash.com/photo-1604654894610-df63bc536371?q=80&w=2000&auto=format&fit=crop') center/cover no-repeat fixed; }
  body::before{ content:''; position:fixed; inset:0; background: radial-gradient(1200px 600px at 80% -10%, rgba(233,30,99,0.25), transparent 60%), radial-gradient(800px 400px at -10% 110%, rgba(233,30,99,0.18), transparent 60%), rgba(0,0,0,0.65); z-index:-1; }
.card { background: var(--vidro); backdrop-filter: blur(18px) saturate(140%); -webkit-backdrop-filter: blur(18px) saturate(140%); width:100%; max-width:640px; border-radius:24px; padding:32px; border:1px solid var(--borda); box-shadow: 0 0 0 1px rgba(255,255,255,0.05) inset, 0 20px 60px rgba(0,0,0,0.5), 0 0 40px var(--rosa-glow); }
.logo { font-size:28px; font-weight:800; text-align:center; margin-bottom:4px; letter-spacing:1px; }
.logo span{color:#fff;text-shadow:0 0 10px #fff}.logo strong{color:var(--rosa); text-shadow:0 0 15px var(--rosa)}
.sub { color:#d0d0d0; font-size:14px; text-align:center; margin-bottom:24px; }
.row{display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:18px;}
  label{font-size:12px; color:#aaa; margin-bottom:6px; display:block; font-weight:600; text-transform:uppercase; letter-spacing:.5px;}
  input[disabled]{ width:100%; padding:14px; border-radius:14px; background: rgba(0,0,0,0.3); border:1px solid var(--borda); color:#eee; font-weight:600; backdrop-filter: blur(4px); }
.topcal{display:flex; justify-content:space-between; align-items:center; margin:8px 0 14px;}
.topcal button{background: rgba(0,0,0,0.3); border:1px solid var(--borda); color:#fff; border-radius:12px; padding:10px 14px; cursor:pointer; font-weight:800; font-size:18px; transition:.2s; backdrop-filter: blur(4px);}
.topcal button:hover{border-color:var(--rosa); box-shadow:0 0 15px var(--rosa-glow)}
.mesano{font-weight:800; font-size:18px; color:#fff; letter-spacing:.5px}
.semana{display:grid; grid-template-columns: repeat(7,1fr); gap:8px; color:#aaa; font-size:12px; text-align:center; margin-bottom:8px; font-weight:600;}
.grid-7 { display:grid; grid-template-columns: repeat(7, 1fr); gap:8px; min-height:280px; }
.dia { padding:14px 0; border-radius:14px; background: rgba(0,0,0,0.3); border:1px solid var(--borda); text-align:center; font-weight:600; cursor:pointer; transition:.2s; user-select:none; backdrop-filter: blur(4px);}
.dia:hover:not(.off) { border-color:var(--rosa); transform: translateY(-2px); box-shadow:0 8px 20px var(--rosa-glow); }
.dia.off { background: rgba(0,0,0,0.2); color:#444; border-color:transparent; cursor:not-allowed; }
.dia.on { border-color: rgba(255,255,255,0.2); }
.dia.sel { background:var(--rosa); color:#000; border-color:var(--rosa); box-shadow: 0 0 25px var(--rosa-glow); font-weight:800; }
.box { display:none; margin-top:24px; padding-top:20px; border-top:1px solid var(--borda); }
.titulo-bloco{font-weight:700; margin:0 0 12px; font-size:15px; color:#ddd;}
.grid-3 { display:grid; grid-template-columns: repeat(3, 1fr); gap:10px; }
.hora { padding:14px; text-align:center; border-radius:14px; background: rgba(0,0,0,0.3); border:1px solid var(--borda); font-weight:600; cursor:pointer; transition:.2s; backdrop-filter: blur(4px);}
.hora:hover{border-color:var(--rosa); box-shadow:0 0 15px var(--rosa-glow)}
.hora.sel { background:var(--rosa); color:#000; border-color:var(--rosa); font-weight:800; box-shadow: 0 0 25px var(--rosa-glow); }
.btn{ width:100%; padding:18px; border-radius:14px; border:0; background: linear-gradient(90deg, #E91E63, #FF4081); color:#fff; font-weight:800; font-size:16px; margin-top:20px; cursor:pointer; transition:.3s; box-shadow: 0 8px 25px var(--rosa-glow); }
.btn:disabled{opacity:.4; cursor:not-allowed; box-shadow:none; filter:grayscale(.5)}
.btn:hover:not(:disabled){transform: translateY(-2px); box-shadow: 0 12px 30px var(--rosa-glow)}
.btn-whats{ width:100%; padding:18px; border-radius:14px; border:0; background: linear-gradient(90deg, var(--rosa), var(--verde-whats)); color:#fff; font-weight:800; font-size:16px; margin-top:12px; cursor:pointer; transition:.3s; box-shadow: 0 8px 25px rgba(37,211,102,0.4); text-decoration:none; display:none; text-align:center;}
.btn-whats:hover{transform: translateY(-2px); box-shadow: 0 12px 30px rgba(37,211,102,0.6)}
.msg{text-align:center; margin-top:14px; font-weight:600}
.msg.ok{color:#4ade80; text-shadow:0 0 10px #4ade80}
.loading{text-align:center; color:#aaa; padding:40px 0;}
</style>
</head>
<body>
  <div class="card">
    <div class="logo"><span>PRETA</span><strong>NAILS</strong></div>
    <div class="sub">Selecione data e horário disponível</div>

    <div class="row">
      <div><label>Nome</label><input id="nome" disabled></div>
      <div><label>WhatsApp</label><input id="zap" disabled></div>
    </div>

    <div class="titulo-bloco">1. Escolha a data</div>
    <div class="topcal">
      <button id="prev"><</button>
      <div class="mesano" id="mesano"></div>
      <button id="next">></button>
    </div>
    <div class="semana"><div>Dom</div><div>Seg</div><div>Ter</div><div>Qua</div><div>Qui</div><div>Sex</div><div>Sáb</div></div>
    <div class="grid-7" id="cal"><div class="loading">Carregando agenda...</div></div>

    <div class="box" id="boxHoras">
      <div class="titulo-bloco">2. Escolha o horário</div>
      <div class="grid-3" id="horas"></div>
    </div>

    <button class="btn" id="btn" disabled>Confirmar Agendamento</button>
    <a href="https://wa.me/+5511982311608" target="_blank" class="btn-whats" id="btnWhats">Falar no WhatsApp 💬</a>
    <div id="msg" class="msg"></div>
  </div>

<script>
// URL NA LINHA CERTA - 1 LINHA SÓ
const AP_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxJmS2PAGTGcjq7Of0109AfdR5lr2TOEe_rCRNCI1iWz9SnrqXF5moav_uBYRwSUQ/exec';

// Pega dados da ficha
const ficha = JSON.parse(localStorage.getItem('fichaPretaNails') || '{}');
document.getElementById('nome').value = ficha.nome || '';
document.getElementById('zap').value = ficha.whatsapp || '';

// Estado
let agenda = {};
let dataSel = '';
let horaSel = '';
let hoje = new Date();
hoje.setHours(0,0,0,0);
let mesAtual = hoje.getMonth();
let anoAtual = hoje.getFullYear();
const LIMITE_ANO = 2099;
const meses = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
const diasSemana = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

document.getElementById('prev').onclick = () => mudarMes(-1);
document.getElementById('next').onclick = () => mudarMes(1);

function mudarMes(dir){
  if(dir === 1 && anoAtual >= LIMITE_ANO && mesAtual === 11) return;
  if(dir === -1 && anoAtual <= hoje.getFullYear() && mesAtual === hoje.getMonth()) return;
  mesAtual += dir;
  if(mesAtual < 0){ mesAtual = 11; anoAtual--; }
  if(mesAtual > 11){ mesAtual = 0; anoAtual++; }
  montarCalendario();
}

async function carregar(){
  try{
    const r = await fetch(AP_SCRIPT_URL + '?action=getAvailability');
    agenda = await r.json();
  }catch(e){ agenda = {}; console.error('Erro API:', e); }
  montarCalendario();
}

function montarCalendario(){
  document.getElementById('mesano').textContent = `${meses[mesAtual]} ${anoAtual}`;
  const cal = document.getElementById('cal');
  cal.innerHTML = '';
  const primeiroDia = new Date(anoAtual, mesAtual, 1).getDay();
  const diasNoMes = new Date(anoAtual, mesAtual + 1, 0).getDate();

  for(let i=0; i<primeiroDia; i++) cal.innerHTML += `<div></div>`;
  for(let dia=1; dia<=diasNoMes; dia++){
    const key = `${anoAtual}-${String(mesAtual+1).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
    const dataDoDia = new Date(anoAtual, mesAtual, dia);
    dataDoDia.setHours(0,0,0,0);
    const div = document.createElement('div');
    div.className = 'dia';
    div.textContent = dia;
    if(dataDoDia < hoje ||!agenda[key] || agenda[key].length === 0){
      div.classList.add('off');
    } else {
      div.classList.add('on');
      div.onclick = () => selecionarDia(key, div);
    }
    cal.appendChild(div);
  }
}

function selecionarDia(key, el){
  document.querySelectorAll('.dia').forEach(x=>x.classList.remove('sel'));
  el.classList.add('sel');
  dataSel = key;
  const box = document.getElementById('boxHoras');
  const wrap = document.getElementById('horas');
  wrap.innerHTML = '';
  (agenda[key]||[]).forEach(h=>{
    const b = document.createElement('div');
    b.className = 'hora'; b.textContent = h;
    b.onclick = () => {
      document.querySelectorAll('.hora').forEach(x=>x.classList.remove('sel'));
      b.classList.add('sel'); horaSel = h; document.getElementById('btn').disabled = false;
    };
    wrap.appendChild(b);
  });
  box.style.display='block';
  document.getElementById('btn').disabled = true;
}

document.getElementById('btn').onclick = async ()=>{
  if(!dataSel ||!horaSel) return;
  const payload = {
    nome:ficha.nome,
    whatsapp:ficha.whatsapp,
    servico:ficha.servico||'Serviço',
    data:dataSel,
    hora:horaSel
  };

  document.getElementById('btn').disabled = true;
  document.getElementById('msg').textContent = 'Enviando Ficha...';
  document.getElementById('msg').className = 'msg';

  try{
    const r = await fetch(AP_SCRIPT_URL + '?action=book', {method:'POST', body:JSON.stringify(payload)});
    const res = await r.json();

    if(res.ok){
      document.getElementById('msg').textContent = 'Agendamento confirmado! ✅';
      document.getElementById('msg').className = 'msg ok';
      document.getElementById('boxHoras').style.display='none';
      document.getElementById('btn').style.display='none';
      document.getElementById('btnWhats').style.display='block';
      localStorage.removeItem('fichaPretaNails');
    } else {
      throw new Error(res.error || 'Erro');
    }
  }catch(e){
    document.getElementById('msg').textContent = 'Erro ao reservar. Tente novamente.';
    document.getElementById('btn').disabled = false;
    console.error('Erro ao bookar:', e);
  }
};

carregar();
</script>
</body>
</html>
